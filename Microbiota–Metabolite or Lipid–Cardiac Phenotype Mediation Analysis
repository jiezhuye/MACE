#networkD3 for med_link
make_link = function(med){
  nodes = data.frame(name =unique(c(med$mebo,med$outcome,med$tax)))
  rownames(nodes)=0:(nrow(nodes)-1)
  nodes$nodegroup = nodes$name
  nodes$nodegroup = ifelse(!is.na(pmatch(nodes$nodegroup,med$mebo)), med[pmatch(nodes$nodegroup,med$mebo),"meboclass"],
                           nodes$nodegroup )
  
  links = rbind( data.frame( source = as.numeric(rownames(nodes)[pmatch(med$tax,nodes$name,duplicates.ok=T)]),
                             target = as.numeric(rownames(nodes)[pmatch(med$mebo,nodes$name,duplicates.ok=T)]),
                             value = round(med$t1.Prop.mediated*100),
                             energy_type= c("#65A8C4", "#FFFF00", "#FF7AB6")[sign(med$t1.inv_med.beta)+2]  ), 
                 data.frame( source = as.numeric(rownames(nodes)[pmatch(med$mebo,nodes$name,duplicates.ok=T)]),
                             target = as.numeric(rownames(nodes)[pmatch(med$outcome,nodes$name,duplicates.ok=T)]),
                             value =round(med$t1.Prop.mediated*100),energy_type=c("#65A8C4", "#FFFF00", "#FF7AB6")[sign(med$t1.med_dv.beta)+2] )
  )
  #links
  
  library(networkD3)
  library(RColorBrewer)
  n <- nrow(nodes)
  qual_col_pals = brewer.pal.info[brewer.pal.info$category == 'qual',]
  col_vector = unlist(mapply(brewer.pal, qual_col_pals$maxcolors, rownames(qual_col_pals)))
  set.seed(0)
  color_scale <- data.frame( domain = c( unique(links$energy_type), nodes[,c("name")] ) )
  color_scale$range = c("#74C476","#2272a9",sample(col_vector, n,replace=T))
  sn = sankeyNetwork(Links = links, 
                     Nodes = nodes, 
                     Source = "source",
                     Target = "target", 
                     Value = "value", 
                     NodeID = "name",
                     nodePadding = 10,
                     units = "TWh", # optional units name for popups
                     fontSize = 12, 
                     # nodeWidth = 30,
                     nodeWidth = 0,
                     LinkGroup = "energy_type",
                     NodeGroup = "nodegroup",
                     width = 900, 
                     height = 1000, # height  1/5, 600*1/2 =300
                     colourScale = JS(
                       sprintf(
                         'd3.scaleOrdinal()  
  				.domain(%s)
  				.range(%s)
					',
                         jsonlite::toJSON(color_scale$domain),
                         jsonlite::toJSON(color_scale$range)
                       )
                     ), 
                     fontFamily = "Arial",
                     margin = list("left"=200,"right"=100)
                     
  )
  
  #   install the newest htmlwidgets
  #   devtools::install_github("ramnathv/htmlwidgets")
  
  library(htmlwidgets)
  
  # now let's use the new htmlwidget function
  sn1 = onRender(
    sn,
    '
	function(el,x){
 			 // select all our node text
  			var node_text = d3.select(el)
   		 .selectAll(".node text")
   		 //and make them match
   		 //https://github.com/christophergandrud/networkD3/blob/master/inst/htmlwidgets/sankeyNetwork.js#L180-L181
		 .attr("x", -150 + x.options.nodeWidth)
   		 .attr("text-anchor", "start");
		}
		'
  )
  sn1
}


