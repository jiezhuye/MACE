read_bimed = function(file){ #Fecel_Lipidomics-mgs.bidirection_mediantion.csv
  bimed = read.csv(paste("E:\\gut\\model\\glm_more_update\\",
                         file,sep=""),as.is=T,head=T,row.names=1)
  # FDR mediation < 0.05 and Pinverse mediation > 0.05
  bimed$t1.ACME.FDR = p.adjust(bimed$t1.ACME.p,method="BH")
  bimed$t2.ACME.FDR = p.adjust(bimed$t2.ACME.p,method="BH")
  
  ## venn diagram
  fdr.cutoff =0.05
  bimed$MediationDirection=c()
  bimed$MediationDirection[bimed$t1.ACME.FDR<fdr.cutoff & 
                             bimed$t1.Prop.mediated.p<0.05 &
                             bimed$t2.ACME.FDR<fdr.cutoff &
                             bimed$t2.Prop.mediated.p<0.05] <- 'both'
  bimed$MediationDirection[bimed$t1.ACME.FDR<fdr.cutoff &
                             bimed$t1.Prop.mediated.p<0.05] <- 'indv_dv1'
  
  med_count<-table(bimed$MediationDirection)
  if(length(med_count)>2){
    library(VennDiagram)
    venn.plot = draw.pairwise.venn(med_count[2]+med_count[1],
                                   med_count[3]+med_count[1],
                                   med_count[1], 
                                   category = c("Direction 1", "Direction 2"), lty = rep("blank",2), fill =c("#4472c4", "#00b050"), alpha = rep(0.5, 2), cat.pos = c(0, 0), cat.cex = c(0.5, 0.5),cat.dist = rep(0.025, 2), scaled = F)
    grid.draw(venn.plot);
  }
  
  bimed =bimed[which(bimed$t1.ACME.FDR<0.05 & bimed$t2.ACME.FDR >0.05 & bimed$t1.Prop.mediated.p<0.05),] 
  med = bimed[bimed$t1.Prop.mediated >0,]
  print(dim(med))
  med
}

# try alluvial diagram
alluvial_plot=function(med){
  library(ggplot2)
  library(ggalluvial)
  library(wesanderson)
  med$fre<-1
  sankey_colors<-c(wes_palette("Darjeeling1", length(unique(med$outcome)), type = "continuous"))
  p1= ggplot(med,aes(axis1 = tax, 
                     axis2 = mebo, 
                     axis3 = outcome,
                     y=med$fre))+
    scale_x_discrete(limits = c("Microbime", "Metabolites", "Heart function")) +
    geom_alluvium(aes(fill = med$outcome),alpha = .55)+
    geom_stratum(alpha = 0,color = adjustcolor( "white", alpha.f = 1),size=1.2)+
    geom_text(stat = "stratum",cex=2,aes(label = after_stat(stratum))) +
    scale_color_manual(values=sankey_colors)+
    scale_fill_manual(values=sankey_colors)+
    theme_minimal()+
    theme(legend.position="none",
          axis.text = element_text(size = 10),
          axis.title = element_blank(),
          axis.text.y = element_blank(),
          panel.grid=element_blank())
  p1
}

# try networkD3
sankeyplot = function(med){
  nodes = data.frame(name =unique(c(med$mebo,med$outcome,med$tax)))
  rownames(nodes)=0:(nrow(nodes)-1)
  nodes$nodegroup = nodes$name
  nodes$nodegroup = ifelse(!is.na(pmatch(nodes$nodegroup,med$mebo)), med[pmatch(nodes$nodegroup,med$mebo),"meboclass"],
                           nodes$nodegroup )
  
  links = rbind( data.frame( source = as.numeric(rownames(nodes)[pmatch(med$tax,nodes$name,duplicates.ok=T)]),
                             target = as.numeric(rownames(nodes)[pmatch(med$mebo,nodes$name,duplicates.ok=T)]),
                             value = med$t1.Prop.mediated,energy_type= c("#65A8C4", "#FFFF00", "#FF7AB6")[sign(med$t1.inv_med.beta)+2]  ), 
                 data.frame( source = as.numeric(rownames(nodes)[pmatch(med$mebo,nodes$name,duplicates.ok=T)]),
                             target = as.numeric(rownames(nodes)[pmatch(med$outcome,nodes$name,duplicates.ok=T)]),
                             value = med$t1.Prop.mediated,energy_type=c("#65A8C4", "#FFFF00", "#FF7AB6")[sign(med$t1.med_dv.beta)+2] )
  )
  head(links)
  
  
  library(networkD3)
  sankeyNetwork(Links = links, 
                Nodes = nodes, 
                Source = "source",
                Target = "target", 
                Value = "value", 
                NodeID = "name",
                nodePadding = 10,
                units = "TWh", # optional units name for popups
                fontSize = 12, 
                nodeWidth = 30,
                LinkGroup = "energy_type",
                NodeGroup = "nodegroup",
                width = 1000,  #width 800, 1000 for pathway
                height = 500 # height  1/5, 600*1/2 =300 for lipids
  )
}

