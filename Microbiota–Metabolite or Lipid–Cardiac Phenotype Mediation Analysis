    tem = gsub("ko:","",unlist(strsplit(x,",",fixed=T)));
    paste(tem[tem%in%ko_m$tax],collapse=";")
  })
  ## some compound do not have microbiome ec
  s3$ec_m = sapply( s3$ec,function(x){ 
    tem = unlist(strsplit(x,",",fixed=T));
    paste( tem[tem%in%s4$ec[s4$ko_m != ""]],collapse=";")
  })
  
