    # make a pathway compound list
    pa_c =c()
    for( pa in unique(rxn2enz)){
      zz = c(pa, paste(names(rxn2enz[rxn2enz==pa]),collapse=","))
      zz = c(zz, length(unlist(strsplit(zz[2],",",fixed=T))) )
      
      pa_c = rbind( pa_c,zz )
