clique_plot = function(med,size){
  library("igraph")
  tmp = med[order(med[,"t1.Prop.mediated"],decreasing=T)[1:min(nrow(med),size)],]
  # make a clique
  #tmp$outcome = paste( tmp$outcome,1:nrow(tmp), sep=" ")
  #tmp$mebo = paste( tmp$mebo,1:nrow(tmp), sep=" ")
  #tmp$tax = paste( tmp$tax,1:nrow(tmp), sep=" ")
  
  # make network with one edge
  oneedge <-function(tmp){
    a1 = tmp[,c("tax","mebo")]
    a2 = tmp[,c("tax","outcome")]
    a3 = tmp[,c("mebo","outcome")]
    colnames(a1)=colnames(a2)=colnames(a3)=c("V1","V2")
    edges = c(tmp$t1.inv_med.beta,tmp$t1.inv_dv.beta,tmp$t1.med_dv.beta)
    links=na.omit( data.frame(rbind(a1,a2,a3)) )
    links$weight=1
    #links$color=ifelse(sign(edges)== -1,"#65A8C4","#FF7AB6")
    links$color=ifelse(sign(edges)== -1,"#74C476","#2272a9")
    
    
    #links$color=ifelse(sign(tmp[,3])== -1,"blue","brown3")
    nodes=data.frame(name=unique(c(as.character(links[,2]),as.character(links[,1]))))
    corr.net <- graph_from_data_frame(d=links, vertices=nodes, directed=T) 
    #E(corr.net)$color <- ifelse(sign(edges)== -1,"#FF7AB6","#65A8C4")
    E(corr.net)$color <- ifelse(sign(edges)== -1,"#74C476","#2272a9")
    E(corr.net)$lty <-rep( c(1,2,1),each=nrow(tmp))
    E(corr.net)$association = c( rep(c("",""),each=nrow(tmp)),
                                 paste(paste(round(tmp$t1.Prop.mediated,3)*100,"%",sep="") ,
                                       # paste("Pmedi = ",tmp$t1.ACME.p,sep="" ),
                                       sep="\n") )  
    #graph_attr(corr.net, "layout") <- layout_with_lgl
    
    corr.net
  }
  oneedge(tmp[1,])
  
  par(mfrow=c(2,4), mar=c(1,4,1,1))
  for (i in 1:nrow(tmp)) {
    set.seed(0)
    xx=oneedge(tmp[i,])
    plot(xx, layout=layout_in_circle(xx), vertex.label.font=2, vertex.label.color="black",
         vertex.label.cex=0.7 ,edge.arrow.size=1,
         edge.curved=0,vertex.size=2,edge.label = E(xx)$association,
         edge.label.color="black")
  }
  
  
}

