    data.frame(pa_c)
  }						
  s1 = vec_df(comec)
  colnames(s1)=c("cpd","ec","ec_num")
  s2 = vec_df(com_pa)	
  colnames(s2)=c("cpd","pathway","pa_num")		
  # outer merge s1, s2
  s3 = merge(x = s1, y = s2, by = "cpd", all = TRUE)
  
  
  
  
  # read ko list to filter some pathway or ec
  s4 = vec_df(ecko)	
  colnames(s4)=c("ec","ko","ko_num")	
