      aso1 = aso[aso$phenotype == out2$phenotype[i],]
      res =c()
      for(ii in 1:length(tem)){  ## multiple ko to one ec, kept the best ko for this ec
        aso2 = aso1[aso1$sgb%in%unlist(strsplit(s4[pmatch(tem[ii],s4$ec),"ko_m"],";",fixed=T)),]
        if(nrow(aso2)>1){
