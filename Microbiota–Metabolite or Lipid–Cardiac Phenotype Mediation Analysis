        }else{
          tem1 = aso2
        }
        res=rbind(res,tem1)
      }
      res = data.frame(res)
      # we kept p<1e-5
      #if( sum(res$Pr<1e-5) >0 ){
      #	res1 = res[res$Pr<1e-5,]
      #	res1$ec = tem[res$Pr<1e-5]
      res1 = res
