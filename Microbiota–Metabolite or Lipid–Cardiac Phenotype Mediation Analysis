  s5$ko_m = sapply( s5$ko,function(x){ 
    tem = gsub("ko:","",unlist(strsplit(x,",",fixed=T)));
    paste(tem[tem%in%ko_m$tax],collapse=";")
  })	
  s5$compleness = 	sapply( s5$ko_m,function(x){ 
    length(unlist(strsplit(x,";",fixed=T)))
  })	
