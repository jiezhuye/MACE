  nn =rep("",length(qvalue))
  nn[qvalue<0.25]=" +"
  nn[qvalue<0.1 & qvalue>=0.05]=" *"
  nn[qvalue<0.05 & qvalue>=0.01 ]=" **"
  nn[qvalue<0.01]=" ***"
  nn
}
mp2= read.csv("Acvd2020.ko.prof.rename.csv",row.names=1,head=T)
mp2=mp2[apply(mp2,1,function(x){mean(x>0)>=0.05}),]
mp2 = log10(mp2+1e-10)
out=run_coxph_more(mp2,info,mace=0,logx=F)#0：death:1:MACE
out=data.frame(out, k_enz[pmatch(out$tax,k_enz$rxn,duplicates.ok=T),-1])
out$tax1 =paste(out$tax,sig_symbol(out$qvalue),sep="")
out$sname = unlist(lapply(strsplit(out$comp,";",fixed=T),function(x){ x[1] }))
out$ftax = paste(out$comp	,out$pathway,sep=";")
out$ftax1 = paste(out$ftax,sig_symbol(out$qvalue),sep="")
write.csv(out,"ko.coxph.death.more.update.csv",quote=F)

