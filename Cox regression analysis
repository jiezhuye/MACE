run_coxph_more=function(mp2,info,mace=0,logx=T){  ### mace=0,deadth; mace=1,mace; mace=2; mace=3
  ### antibiotic already removed.
  
  ### intersect meta and metagenomic
  nm=intersect(colnames(mp2),rownames(info))
  print(length(nm))
  
  info=info[pmatch(nm,rownames(info)),]
  mpx=mp2[,pmatch(rownames(info),colnames(mp2))]
  if(logx ==T){### microbime only
    mpx=mpx[apply(mpx,1,function(x){mean(x>0)>=0.05}),]
    library(compositions)
    ### column is variable, row is sample,clr transform
    if( grepl("k__",rownames(mpx)[1]) ){ # mp2
      mpx = t(data.frame( clr(data.frame(t(mpx)/100+1e-10))))
    }else{
      mpx = t(data.frame( clr(data.frame(t(mpx)+1e-12))))
    }
  }
  dim(mpx)
  #	i=which(grepl("hallii",rownames(mpx)))
  #i=608
  #plot(log10(t(mpx1[i,])+1e-12), t(mpx[i,])) # CLR is very in consistent for bracken
  
  
  ### coxph for  metagenomics		
  library("survival")
  
  ## BB beta???????ͼ?
  ## ??ͨ?????ͼ?(CCB)
  ## ???ӱ????Ƽ?(PPIs)
  ## Ѫ?ܽ?????ת??ø???Ƽ?(ACEI)
  ## confounders
  cder_var=c("Center","age","Sex","drinking","smoking","BB","CCB","PPI","ACEI","Aspirin","Clop","ARB","Tica","AGIs","Biguanide")
  #DOI: 10.1056/NEJMoa1109400
  #traditional  cardiovascular risk factors
  # performed Cox proportional-hazards regression analysis with adjustment for traditional 
  # cardiovascular risk factors (age, sex, systolic blood 
  # pressure, presence or absence of diabetes mellitus, 
  # low-density and high-density lipoprotein cholesterol levels, triglyceride levels, and smoking status) 
  # and for log-transformed high-sensitivity C-reactive protein levels (both alone and with myeloperoxidase), 
  #  the log-transformed estimated glomerular filtration rate, total leukocyte count, 
  # body-mass index, medication history, and angiographic extent of coronary artery disease
  #clinc = data.frame( gender,lnage,lntrsbp,lntrdbp=log(info$DBP),diabet,lnhdlc,
  #	lnldlc=log(info$LDLC*38.67),lnchol,lntrig = log(info$TRIG*38.67),smoke, lntcrp = log(info$CRP_G),
  #	lnwbc = log(info$WBC),bmi=info$BMI,SYNTAX=log(info$SYNTAX+0.01),
  #	info[,c("BB","CCB","PPI","ACEI","Aspirin","Clop")])
  cder_var= c("Center","age","Sex","drinking","smoking","BB","CCB","PPI","ACEI","Aspirin","Clop","ARB","AGIs","Biguanide",
              "SBP","DBP","hyperT","HDLC","LDLC","TRIG","BMI")  # 52 high,23 lw for WBC, 
  # race was categorized as white, black, Asian/Pacific Islander, American Indian/Alaska Native, multiracial, not specified, or not documented (ie, missing).
  # LDLC and CHOL, is 0.8 correlation, just kept one, we kept LDLC.
  # Tica is -0.77 with Clop, drop Tica
  sort(apply(info[,cder_var],2,function(x){ mean(is.na(x)) })) ## stat the missing 
  cder= info[,cder_var]
  
  #cder = cder[,apply(cder,2,function(x){mean(is.na(x))})<0.3] ### missing >30%, impute is no mean
  colnames(cder)
  ### fill NA with median for misssing < 20%
  for ( var in colnames(cder)[apply(cder,2,function(x){mean(is.na(x))})<0.2]){
    cder[is.na(cder[,var]),var]=median(cder[,var],na.rm=T)
  }
  head(cder)
  sort(apply(cder,2,function(x){ mean(is.na(x)) })) ## stat the missing 
  # for missing >20%, categorized as low ,high, or not documented (ie, missing)
  transx =function(x,low_band=4, high_band=10){
    y=rep("miss",length(x))
    y[which(x<=low_band)]="first"
    y[which(x>=high_band)]="later"
    y[which(x<high_band & x>low_band )]="cormal"
    factor(y)
  }
  #cx1 = cor(cder,use="pairwise.complete.obs")
  #  cder$WBC = transx(cder$WBC,4,10)
  cder$BMI = transx(cder$BMI,11,27)
  cder$smoking = transx(cder$smoking,-0.1,0.9)
  cder$drinking = transx(cder$drinking,-0.1,0.9)
  cder$SBP = transx(cder$SBP,120,140)
  cder$DBP = transx(cder$DBP,-0.1,80)
  
  for(var in c("age","HDLC","LDLC","TRIG")){ # log 
    cder[,var]= log(cder[,var])
  }
  #cx1 = cor(cder[,colnames(cder)%in%c("Center","age","Sex","BB","CCB","PPI","ACEI","Aspirin","Clop","ARB","Tica","AGIs","Biguanide",
  #		"hyperT","HDLC","LDLC","CHOL","TRIG")])
  # pheatmap(cx1)
  # library(caret)
  #findCorrelation(cx1,0.7)
  #plot(cder$LDLC, cder$CHOL)
  
  if(mace == 0){
    
    ## Death
    exp_dat = data.frame(
      MACE = apply(info[,c("Death","Death")], 1, function(x){
        x = as.numeric(x)
        if(all(is.na(x))) NA else as.numeric(sum(x, na.rm = TRUE) > 0)
      }),
      MACE_time_wdl = apply(info[,c("Death_time","Death_time")], 1, function(x){
        x = as.numeric(x)
        if(all(is.na(x))) NA else min(x, na.rm = TRUE)
      }),
      cder
    )
    
  } else if(mace == 1){
    
    ## MACE4
    exp_dat = data.frame(
      MACE = as.numeric(info$MACE4),
      MACE_time_wdl = as.numeric(info$MACE4_time),
      cder
    )
    
  } else if(mace == 2){
    
    ## MACE5
    exp_dat = data.frame(
      MACE = as.numeric(info$MACE5),
      MACE_time_wdl = as.numeric(info$MACE5_time),
      cder
    )
    
  }else if(mace == 3){
    
    ## MACE5
    exp_dat = data.frame(
      MACE = as.numeric(info$MACE6),
      MACE_time_wdl = as.numeric(info$MACE6_time),
      cder
    )
    
  }else if(mace == 4){
    
    ## MACE5
    exp_dat = data.frame(
      MACE = as.numeric(info$MACE7),
      MACE_time_wdl = as.numeric(info$MACE7_time),
      cder
    )
    
  } else {
    
    stop("Unknown mace value")
  }
  
  ## 特殊样本强制事件
  exp_dat[info[,1] == "M19011317a", "MACE"] = 1
  
  print(table(exp_dat$MACE))
  
  print("mean visit time:")
  print(mean(exp_dat$MACE_time_wdl,na.rm=T))
  
  res1=t(apply(mpx,1,function(y){
    tmp=data.frame(target=y,exp_dat)
    colnames(tmp)[1]="target"
    mod=coxph(Surv(MACE_time_wdl, MACE) ~ . , data=tmp)## log10 abundance
    coef(summary(mod))["target",]
  }))
  
  res1=data.frame(res1)
  res1$qvalue=p.adjust(res1[,"Pr...z.."],method="BH")
  res1$tax=unlist(lapply(strsplit(rownames(res1),"|",fixed=T),function(x){x[length(x)]}))
  rownames(res1)=res1$tax
  print("pvalue<0.05: ")
  print(sum(res1[,"Pr...z.."]<0.05))
  print("qvalue<0.1: ")
  print(sum(res1[,"qvalue"]<0.1))
  res1
}

