#cli
# 1. 载入必要的库
library(caret)

# 2. 定义变量名清单
cder_var <- c("Center", "age", "Sex", "drinking", "smoking", "BB", "CCB", "PPI", "ACEI", "Aspirin", "Clop",
              "SBP", "DBP", "hyperT", "HDLC", "LDLC", "TRIG", "BMI")

# 3. 提取临床指标
cder <- info[, cder_var]

# 4. 处理缺失值 < 10% 的变量：使用中位数插补
# 这种方法适用于低缺失率的连续变量
low_miss_vars <- colnames(cder)[apply(cder, 2, function(x) mean(is.na(x))) < 0.1]
for (var in low_miss_vars) {
  if (is.numeric(cder[[var]])) {
    cder[is.na(cder[, var]), var] <- median(cder[, var], na.rm = TRUE)
  }
}

# 5. 处理缺失值 > 10% 的变量：转化为分类因子
# 定义转换函数，将数值划分为等级并保留 "miss" 类别以应对缺失数据
transx <- function(x, low_band, high_band) {
  y <- rep("miss", length(x))
  y[which(x <= low_band)] <- "first"
  y[which(x >= high_band)] <- "later"
  y[which(x < high_band & x > low_band)] <- "normal"
  return(factor(y))
}

# 根据临床意义设定阈值进行分类
cder$BMI      <- transx(cder$BMI, 11, 27)
cder$smoking  <- transx(cder$smoking, -0.1, 0.9)
cder$drinking <- transx(cder$drinking, -0.1, 0.9)
cder$SBP      <- transx(cder$SBP, 120, 140)
cder$DBP      <- transx(cder$DBP, -0.1, 80)

# 6. 对关键生化指标进行对数转换
# 在组学研究中，对数转换有助于处理偏态分布的数据
for (var in c("age", "HDLC", "LDLC", "TRIG")) {
  # 确保数据为正数以进行 log 转换
  cder[, var] <- log(cder[, var] + 1e-6) 
}

# 7. 再次检查并填补可能残余的缺失值
jclin <- cder
remaining_na_vars <- colnames(jclin)[apply(jclin, 2, function(x) any(is.na(x)))]
for (var in remaining_na_vars) {
  if (is.numeric(jclin[[var]])) {
    jclin[is.na(jclin[, var]), var] <- median(jclin[, var], na.rm = TRUE)
  }
}

# 8. 哑变量化处理 (Dummy Variables)
# 将分类变量（包括 'miss' 类别）转化为数值矩阵
# [,-1] 用于移除截距项
jclin_mat <- model.matrix(~ . , data = jclin)[, -1]
jclin <- as.data.frame(jclin_mat)

# 9. 定义并执行相关性过滤
# 移除相关系数 > 0.8 的冗余变量以减少多重共线性
findcor <- function(conf) {
  res.cor <- cor(conf, use = "pairwise.complete.obs")
  res.cor[is.na(res.cor)] <- 0
  # 使用 caret 包的 findCorrelation 函数
  res.id <- findCorrelation(res.cor, cutoff = 0.8, exact = FALSE)
  if (length(res.id) != 0) {
    conf <- conf[, -res.id]
  }
  return(conf)
}

# 得到最终用于建模的临床数据矩阵
jclin_final <- findcor(jclin)

# 查看处理后的维度
print(dim(jclin_final))
bmp2 <- as.data.frame(t(jclin_final))
mp2 <- bmp2
