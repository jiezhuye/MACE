reselect_predc =  function(end_var,end_time,dat ){
  library("doMC")
  registerDoMC(16) #number of cores on the machine
  id1=which(info[,end_var]==1)	
  id2=which(info[,end_var]==0)	
  set.seed(0)
  ## re-selection control
  predx= foreach(i= 1:25, .combine=rbind ) %dopar% {
    id3= sample(id2,length(id1),replace=T)
    id=c(id1,id3)
    all.rf <- randomForest( dat[id,] ,  factor(info[id,end_var]),ntree=1000 , importance=T)
    xj = all.rf$importance[,"MeanDecreaseGini"]
    names(xj) = rownames(all.rf$importance)
    write.csv(xj,paste("E:/gut/model/figure1a/cli/",end_var,"_boot_",i, ".20240406.imp.csv",sep=""))
    
    impvar <- rownames(all.rf$importance)[order(all.rf$importance[, 1], decreasing = TRUE)[1:min(50,nrow(all.rf$importance))]]
    rf <- randomForest( dat[id,impvar] ,  factor(info[id,end_var]),ntree=1000 , importance=T)
    #print(rf$confusion)	
    data.frame(pred = rf$votes[,2], measure= info[id,end_var],id=info[id,1],boot=i,type=end_var )						
  }
  
  #### match case, control
  matchvar=c("age","Sex","weight","drinking","smoking")
  info1=info[,matchvar]
  for(i in 1:ncol(info1)){
    info1[is.na(info1[,i]),i]=median(info1[,i],na.rm=T)
  }
  info1=scale(info1)
  dix = as.matrix(dist(info1))
  id3=c()
  for(case in id1){
    id3=c(id3,id2[which.min(dix[case,id2])])
  }
  id=c(id1,id3)
  all.rf <- randomForest( dat[id,] ,  factor(info[id,end_var]),ntree=1000 , importance=T)
  xj = all.rf$importance[,"MeanDecreaseGini"]
  names(xj) = rownames(all.rf$importance)
  write.csv(xj,paste("E:/gut/model/figure1a/cli/",end_var,"_boot_",100, ".20240406.imp.csv",sep=""))
  
  impvar <- rownames(all.rf$importance)[order(all.rf$importance[, 1], decreasing = TRUE)[1:min(50,nrow(all.rf$importance))]]
  rf <- randomForest( dat[id,impvar] ,  factor(info[id,end_var]),ntree=1000 , importance=T)
  print("match+++++++++")	
  print(roc(factor(info[id,end_var]),rf$votes[,2],ci=T)$ci[2] )
  predx=rbind(predx, data.frame(pred = rf$votes[,2], measure= info[id,end_var],id=info[id,1],boot=100,type=end_var ))						
  
  tmp =data.frame(target=factor(info[id,end_var]), log10(dat[id,impvar]+1e-12) )
  colnames(tmp)[1]="target"
  mod = glm(target ~ ., data=tmp,family = binomial(link = "logit") )
  saveRDS(mod,paste("E:/gut/model/figure1a/cli/",end_var,".20240406.glm.rds",sep=""))
  predx
  
  
}
