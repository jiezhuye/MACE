  .calc_robust_metrics <- function(lp, time, status, times_eval) {
    # 1. 检查方向 (使用 Spearman 相关性)
    rho <- cor(lp, status, method = "spearman")
    is_inverted <- rho < 0
    # 2. 如果是反向的，对 lp 取反
    adj_lp <- if(is_inverted) -lp else lp
    # 3. 计算 C-index (Hmisc 需要传入负的 lp 来代表高风险)
    c_idx <- as.numeric(Hmisc::rcorr.cens(-adj_lp, survival::Surv(time, status))["C Index"])
    # 4. 计算 AUC
    roc <- timeROC::timeROC(T = time, delta = status, marker = adj_lp, cause = 1, weighting = "marginal", times = times_eval, iid = FALSE)
    list(c_index = c_idx, auc = roc$AUC, inverted = is_inverted)
  }
  
  .parse_rx_date <- function(x) {
    if (inherits(x, "Date")) return(x)
    if (inherits(x, "POSIXt")) return(as.Date(x))
    
    x_chr <- trimws(as.character(x))
    x_chr[x_chr %in% c("", "NA", "NaN", "NULL")] <- NA
    
    out <- as.Date(rep(NA_character_, length(x_chr)))
    names(out) <- names(x_chr)
    
    # Handle Excel-like serial dates (days since 1899-12-30)
    is_num <- !is.na(x_chr) & grepl("^[0-9]+(\\.[0-9]+)?$", x_chr)
    if (any(is_num)) {
      x_num <- suppressWarnings(as.numeric(x_chr[is_num]))
      is_excel <- !is.na(x_num) & x_num > 10000 & x_num < 60000
      if (any(is_excel)) {
        out[which(is_num)[is_excel]] <- as.Date(x_num[is_excel], origin = "1899-12-30")
      }
    }
    
    # Try common explicit formats (including timestamps)
    fmts <- c(
      "%Y/%m/%d",
      "%Y-%m-%d",
      "%Y.%m.%d",
      "%Y/%m/%d %H:%M:%S",
      "%Y-%m-%d %H:%M:%S",
      "%Y/%m/%d %H:%M",
      "%Y-%m-%d %H:%M",
      "%Y%m%d"
    )
    for (fmt in fmts) {
      idx <- which(is.na(out) & !is.na(x_chr))
      if (length(idx) == 0) break
      out[idx] <- as.Date(x_chr[idx], format = fmt)
    }
    
    out
  }
  
