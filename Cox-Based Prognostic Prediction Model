  estinc=1-survpr4K
  
  #split into deciles
  d$dec=as.numeric(cut2(estinc, g=5))
  table(d$dec)
  #check that there are 5 or more events in each group
  #if not then collapse groups
  xx = table(d$dec, d$status)
  
  if( any(xx[,2] <5) ){
    outj = list("GND.result",out_pred,spar_var1 )
  }else{
    #calculate the GND test
    GND.result=GND.calib(pred=estinc, tvar=d$fu.time, out=d$status, 
                         cens.t=adm.cens, groups=d$dec, adm.cens=adm.cens)
    
    outj = list(GND.result,out_pred,spar_var1 )
  }
  
}


mark_pick =function(mp2, mark,corcut=0.5,pcut=0.1){
  #print(mark[mark[,"Pr...z.."]<0.05,"tax"])
  # get marker profile, we'd better not kept variable more than 35. 
  newn = unlist(lapply(strsplit(rownames(mp2),"|",fixed=T),function(x){x[length(x)]}))
  #test =mark[mark[,"Pr...z.."]<0.05,"tax"] ##2024/04/10
  test =mark[mark[,"Pr...z.."]<pcut,"tax"]
  #test = test[grepl("g__|s__|t__",test)]
  mark_p = mp2[pmatch(test,newn),]
  
  
  # remove colinear
  library(caret)
  cor1=cor(t(mark_p),method="spearman")
  cor2=cor1
  rownames(cor2)=colnames(cor2)=test
  #corcut =0.5 # for microbiome
  #corcut =0.8 # for metabolites
  id=findCorrelation(cor2,corcut)
  colnames(cor2)[id]
  round(cor2[id,apply(cor2[id,],2,function(x){any(x>corcut)})],2)
  library(pheatmap)
  cor2 =cor2[id,apply(cor2[id,],2,function(x){any(x>corcut)})]
  cor2[abs(cor2)>corcut]=1
  pheatmap(round(cor2,2))
  
  # we kept the most significant one
  if(length(id)>0){
    kep =rownames(cor1)[-id]
    dropx = rownames(cor1)[id]
    for(xx in id){
      jj = mark[pmatch(colnames(cor1)[cor1[xx,]>corcut],mark$tax),]
      kep = kep[!kep%in%jj$tax] ## clean this group
      kep= c(kep,jj[which.min(jj[,"qvalue"]),"tax"]) ## add the need
    }
    kep = unique(kep)
    mark[pmatch(kep,mark$tax),]
    
  }
  mark_p1 = mark_p[kep,]
  dim(mark_p1)
  
  #if(nrow(mark_p1)>35){ # no more than 35 feactures
  #	mark_p1 = mark_p1[rownames(mark_p1)[order(mark[pmatch(rownames(mark_p1),mark$tax),"Pr...z.."])[1:35]],]
  #}
  print(rownames(mark_p1))
  mark_p1
}

