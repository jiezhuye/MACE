  df3 = data.frame(rbind(df2[,c("coef","se.coef.","panel","jjtax","sig","tax")],
                         h1[,c("coef","se.coef.","panel","jjtax","sig","tax")]))
  
  
  
  
  print("number of significant metabolites")
  print(length(unique(df3$jjtax)))
