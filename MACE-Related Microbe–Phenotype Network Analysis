process_imp=function(sp="3"){
  pref2 = "E:/gut/model/"
  ## all
  #stra_1.imp_skin
  f1=paste(pref2,"stra_",sp,".imp_skin.csv",sep="")
  glm_a=read.csv(f1,as.is=T,head=T,row.names=1)
  imp = glm_a
  library(reshape2)
  cc = melt(as.matrix(imp))
  cc$top=0
  cc1=c()
  for(va in as.character(unique(cc$Var2))){
    tmp = cc[as.character(cc$Var2)==va,]
    tmp =tmp[order(tmp$value,decreasing=T)[1:15],]
    tmp$top =1
    cc1=rbind(cc1,tmp)
  }
  cc$top[pmatch(paste(cc1$Var1, cc1$Var2),paste(cc$Var1, cc$Var2))]=1
  cc
}

