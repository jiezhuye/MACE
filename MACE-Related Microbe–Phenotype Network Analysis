# scatter plot
scatter_microbe_clinc = function(mp2, info,pathway=c("LVEF"),
                                 sgb=unique(aso[aso$phenotype=="LVEF" & aso$qvalue<0.1,"sgb"]),sp=3,
                                 v1= "ftax1", v2 ="tax1"){
  # f1 is file name of microbiome , f2 is the filename of metabolites
  # pathway =c("LIPID_P_0033","LIPID_P_0732","LIPID_N_0582","LIPID_N_0240","LIPID_P_0031","LIPID_P_0071")
  # sgb =c("s__Megasphaera_micronuciformis","s__Saccharomyces_cerevisiae")
  #pathway =unique(c("MEDN221","MEDN562","MEDN704","MEDP454","MEDN821","MEDN227","MEDN720","MEDP214"))
  # sgb =c("s__Enterococcus_faecium","s__Stenotrophomonas_maltophilia","s__Saccharomyces_cerevisiae","s__Enterococcus_avium","s__Enterococcus_casseliflavus")
  
  #pathway =  mark_mebo[mark_mebo[,"Pr...z.."]<0.05,"tax"]
  # sgb = mark_bracken[mark_bracken[,"Pr...z.."]<0.05,"tax"] 
  # mark_bracken[grepl("casse",mark_bracken[,"tax"]),]
  # f1 ="clean\\Acvd2020.mp2.prof.rename.csv"
  d1 = mp2
  rownames(d1) =unlist(lapply(strsplit(rownames(d1),"|",fixed=T),function(x){x[length(x)]}))
  
  # f2 = "clean\\Acvd2020.Fecel-Metabolomics.prof.rename.T.csv"
  # f2 = "clean\\Acvd2020.Fecel-Lipidomics.prof.rename.T.csv"
  d2 = t(info)
  # intersect
  nm  = intersect(colnames(d1),colnames(d2))
  length(nm)
  d1 = d1[,pmatch(nm,colnames(d1))]
  d2 = d2[,pmatch(nm,colnames(d2))]
  
  # association between mp2 and clinical
  aso = process_sig(sp,pref2)
  #aso$sgb1 = unlist(lapply(strsplit(aso$sgb,".",fixed=T),function(x){x[length(x)]}))
  
  #### prepare data for plot
  ### long format
  df =c()
  for(ss in sgb){
    for(gg in pathway){
      bb = as.numeric(t(d1[ss,]))
      #bb = log10(bb + min(bb[bb>0])/10 )
      bb = log10(bb + 1e-10 )
      df = rbind(df,data.frame(var1 = mark_mebo[which(mark_mebo$tax == gg),v2], var2 = mark_bracken[which(mark_bracken$tax == ss),v1],
                               var3 = paste( mark_bracken[which(mark_bracken$tax == ss),v1] ,mark_mebo[which(mark_mebo$tax == gg),v2] ,sep="|"), 
                               mebo = as.numeric(t(d2[gg,])), meta = bb,qv=aso[which(aso$phenotype ==gg & aso$sgb ==ss),"qvalue"]) )
    }
  }
  
  library(ggplot2)
  library(MASS)
  
  
  
  
  dat_text  = df[!duplicated(df[,c("var1","var2")]),c("var1","var2","qv")]	
  dat_text$qv = paste("q = ",ifelse(dat_text$qv <1e-3,round(dat_text$qv,6), round(dat_text$qv,3) ))
  
  
  ggplot(data =df , aes(y = meta, x = mebo)) +    
    geom_point(pch = 21,size=1,alpha=0.5)+
    #stat_compare_means(comparisons = my_comparisons,method="wilcox.test")+
    facet_wrap(~var2 ,ncol=ceiling(length(sgb)/6),scale="free_y" )+
    geom_smooth(method="lm" ,color ="#2272a9",se=T )+
    geom_text(
      data    = dat_text,
      mapping = aes(x = -Inf, y = -Inf, label = qv),
      hjust   = -0.1,
      vjust   = -1
    )+
    xlab("")+
    ylab("log10(mp2 abun)")+
    theme_classic() +
    theme(axis.text.x = element_text(angle = 90, hjust = 1),
          legend.title = element_blank(),
          legend.position = "none" ,
          strip.text.x = element_text(size = 5) )
  
  
}
